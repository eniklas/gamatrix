# Copy to .env for local development. Loaded by both docker-compose and `just`.
# In AWS these values come from environment variables, Secrets Manager, and SSM.

# Marks this as a local dev run (relaxes the production JWT_SECRET check, uses
# inline DB parsing instead of S3 events, etc.). Never set in AWS.
LOCAL_DEV=true

# Secret used to sign JWT session cookies. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# In AWS this is generated by CDK and read from Secrets Manager (JWT_SECRET_NAME).
JWT_SECRET=change-me-in-production

# IGDB / Twitch API credentials (https://api-docs.igdb.com/#getting-started).
# In AWS these come from Secrets Manager.
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=

# Sender address for password-reset emails. Locally this just shows up in
# mailhog (http://localhost:8025); in AWS it must be an SES-verified identity.
EMAIL_FROM=noreply@example.com

# Base URL used to build password-reset links in emails.
APP_BASE_URL=http://localhost:8088

# WebAuthn relying-party scope. Production must use the stable canonical HTTPS
# domain and explicitly list its exact origin.
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Gamatrix
WEBAUTHN_ORIGINS=["http://localhost:8088"]

# How long (days) before cached IGDB data is considered stale and re-enriched.
IGDB_STALE_DAYS=30

# DynamoDB table name prefix (lets multiple stacks share an account).
TABLE_PREFIX=gamatrix

# Name of the S3 bucket that receives GOG Galaxy DB uploads.
UPLOAD_BUCKET=gamatrix-gog-db-uploads

# Optional browser-facing S3 endpoint. Locally the app container talks to minio
# on the Docker network (`http://minio:9000`), but browsers need a host
# reachable URL such as `http://localhost:9000`.
PUBLIC_S3_ENDPOINT_URL=http://localhost:9000
